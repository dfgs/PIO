<UserControl x:Class="PIO.Console.Views.ToolBarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PIO.Console.Views"
             mc:Ignorable="d" 
             d:DesignWidth="800" Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
	<StackPanel Orientation="Horizontal">
		<Button Command="{Binding RefreshCommand}" Margin="2">
			<Image Source="/PIO.Console;component/Images/arrow_refresh.png" Stretch="None"  />
		</Button>
	</StackPanel>
</UserControl>
